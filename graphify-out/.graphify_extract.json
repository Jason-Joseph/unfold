      "id": "card_flip_animation",
      "label": "Card Flip Animation",
      "type": "feature",
      "description": "CSS 3D flip animation using rotateY(180deg) on the .card element. Triggered by tapping/clicking the card. Uses transform-style: preserve-3d and backface-visibility: hidden on .face elements. Transition: 0.6s cubic-bezier.",
      "confidence": "EXTRACTED",
      "source_location": "index.html"
    },
    {
      "id": "card_deal_animation",
      "label": "Card Deal Animation",
      "type": "feature",
      "description": "CSS @keyframes 'deal' animation applied when a new card is drawn. Animates from translateY(30px) rotate(-4deg) scale(0.93) opacity 0.2 to normal state. Duration: 0.45s.",
      "confidence": "EXTRACTED",
      "source_location": "index.html"
    },
    {
      "id": "deck_toggle",
      "label": "Deck Toggle / Chip Filter",
      "type": "feature",
      "description": "UI chips at the top allow enabling/disabling individual decks. Active decks are tracked in a Set. 'All decks' chip enables all simultaneously. Toggling rebuilds the card pool.",
      "confidence": "EXTRACTED",
      "source_location": "index.html"
    },
    {
      "id": "card_pool",
      "label": "Card Pool",
      "type": "component",
      "description": "Runtime array 'pool' holding unseen cards for the current session. Built by iterating active decks and filtering out already-seen cards. Shuffled using Fisher-Yates algorithm.",
      "confidence": "EXTRACTED",
      "source_location": "index.html"
    },
    {
      "id": "progress_tracking",
      "label": "Progress Tracking",
      "type": "feature",
      "description": "Tracks which cards have been answered or skipped per deck, stored as 'deckKey:idx' keys in the 'seen' object. Persisted to localStorage under key 'unfold_v1'. Progress bar and count shown in UI.",
      "confidence": "EXTRACTED",
      "source_location": "index.html"
    },
    {
      "id": "localstorage_persistence",
      "label": "localStorage Persistence",
      "type": "feature",
      "description": "Card state (answered/skipped) is persisted in localStorage under key 'unfold_v1'. Falls back gracefully if localStorage is unavailable. Checked via try/catch on a test write.",
      "confidence": "EXTRACTED",
      "source_location": "index.html"
    },
